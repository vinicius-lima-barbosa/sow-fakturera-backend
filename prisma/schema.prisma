generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model User {
  id        String   @id @default(uuid())
  name      String
  email     String   @unique
  password  String
  createdAt DateTime @default(now()) @map("created_at")

  @@map("users")
}

model Product {
  id            String   @id @default(uuid())
  articleNumber Int      @unique @map("article_number")
  name          String
  inPrice       Int      @map("in_price")
  price         Int
  unit          String
  inStock       BigInt   @map("in_stock")
  description   String
  createdAt     DateTime @default(now()) @map("created_at")
  updatedAt     DateTime @updatedAt @map("updated_at")

  @@map("products")
}
