generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model User {
  id        String   @id @default(uuid())
  name      String
  email     String   @unique
  password  String
  createdAt DateTime @default(now()) @map("created_at")

  @@map("users")
}

model Product {
  id            String   @id @default(uuid())
  articleNumber Int      @unique @map("article_number")
  name          String
  inPrice       Int      @map("in_price")
  price         Int
  unit          String
  inStock       Int      @map("in_stock")
  description   String
  createdAt     DateTime @default(now()) @map("created_at")
  updatedAt     DateTime @updatedAt @map("updated_at")

  @@map("products")
}

model LoginPageMetadata {
  id       String @id @default(uuid())
  // Language
  language String @unique

  // Header or NavbAr
  home         String
  order        String
  ourCostumers String @map("our_costumers")
  contactUs    String @map("contact_us")

  // Login Card
  loginHeader             String @map("login_header")
  emailLabel              String @map("email_label")
  emailField              String @map("email_field")
  passwordLabel           String @map("password_label")
  passwordField           String @map("password_field")
  loginButton             String @map("login_button")
  registerButton          String @map("register_button")
  forgottenPasswordButton String @map("forgotten_password_button")

  // Footer
  footerTitle     String @map("footer_title")
  footerHome      String @map("footer_home")
  footerOrder     String @map("footer_order")
  footerContactUs String @map("footer_contact_us")
  rights          String @map("footer_rights")

  @@map("login_page_metadata")
}
